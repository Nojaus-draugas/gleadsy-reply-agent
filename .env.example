# Instantly
INSTANTLY_API_KEY=
INSTANTLY_WORKSPACE_ID=
REPLY_SOURCE=webhook
POLLING_INTERVAL_SECONDS=60

# Claude API
ANTHROPIC_API_KEY=

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=./token.json
GOOGLE_CALENDAR_ID=primary

# Slack
SLACK_WEBHOOK_URL=

# Agent config
CONFIDENCE_THRESHOLD=0.7
MAX_REPLIES_PER_THREAD=5
REPLY_COOLDOWN_HOURS=4
TIMEZONE=Europe/Vilnius

# Test mode - logs replies to Google Sheets instead of sending via Instantly
TEST_MODE=false

# Translation + rewrite models (foreign-language approval flow)
TRANSLATION_MODEL=claude-haiku-4-5-20251001
REWRITE_MODEL=claude-sonnet-4-6

# Dashboard base URL (used in Slack approval-pending links)
# Prod:     https://reply.gleadsy.com
# Legacy:   https://gleadsy-reply-agent.onrender.com
DASHBOARD_BASE_URL=https://reply.gleadsy.com
